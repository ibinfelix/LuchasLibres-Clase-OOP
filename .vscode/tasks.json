{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: Build C++ Project",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "Battle.cpp",
                "Luchador.cpp",
                "-o",
                "Battle.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compiles all source files with g++ compiler."
        }
    ],
    "version": "2.0.0"
}